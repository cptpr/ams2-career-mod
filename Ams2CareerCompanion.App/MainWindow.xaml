                                    <TextBlock Margin="0,14,0,0" Style="{StaticResource CaptionTextStyle}" Text="STARTUP ERROR LOG" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource BodyTextStyle}" Text="{Binding Diagnostics.StartupErrorLogPath}" />
                                    <TextBlock Margin="0,14,0,0" Style="{StaticResource CaptionTextStyle}" Text="RUN ID" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource BodyTextStyle}" Text="{Binding Diagnostics.CurrentRunId}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>
                </TabControl>
            </ScrollViewer>
    </Grid>
</Window>

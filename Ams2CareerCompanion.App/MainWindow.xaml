                                                            <TextBlock Margin="0,4,0,0" Style="{StaticResource CaptionTextStyle}" Text="{Binding Subtitle}" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource BodyTextStyle}" Text="{Binding DetailLine}" />
                                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource AccentGreenBrush}" Text="{Binding ResultTag}" />
                                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource BodyTextStyle}" Text="{Binding CleanlinessTag}" />
                                                        <TextBlock Grid.Column="4" VerticalAlignment="Center" Style="{StaticResource BodyTextStyle}" Text="{Binding ReviewTag}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="18,0,0,0">
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="RESULT SUMMARY" />
                                        <TextBlock Margin="0,16,0,0"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Text="{Binding SelectedRecentResultHeadline}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   Text="{Binding SelectedRecentResultDetails}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,18,0,0"
                                        Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="SEASON TO DATE" />
                                        <TextBlock Margin="0,16,0,0"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   Text="{Binding SeasonSummaryText}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource SidebarHeaderGlyphStyle}" Text="&#xE713;" />
                        <TextBlock Margin="14,0,0,0" Style="{StaticResource SidebarHeaderTextStyle}" Text="SETTINGS" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource PageTitleStyle}" Text="SETTINGS" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource BodyTextStyle}"
                                       Text="Setup, diagnostics, automation behavior, and profile management. Raw logs stay accessible but do not dominate the normal user path." />
                        </StackPanel>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="0.95*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="SETUP" />
                                    <TextBlock Margin="0,18,0,0" Style="{StaticResource CaptionTextStyle}" Text="AMS2 INSTALL PATH" />
                                    <TextBox Margin="0,8,0,0"
                                             Padding="12"
                                             Background="#0D151D"
                                             BorderBrush="#2A3946"
                                             BorderThickness="1"
                                             Foreground="{StaticResource TextMainBrush}"
                                             Text="{Binding InstallPathText}" />
                                    <TextBlock Margin="0,16,0,0" Style="{StaticResource CaptionTextStyle}" Text="AMS2 PROFILE PATH" />
                                    <TextBox Margin="0,8,0,0"
                                             Padding="12"
                                             Background="#0D151D"
                                             BorderBrush="#2A3946"
                                             BorderThickness="1"
                                             Foreground="{StaticResource TextMainBrush}"
                                             Text="{Binding RaceDesk.SessionPresetStatusText}" />
                                    <TextBlock Margin="0,18,0,0" Style="{StaticResource BodyTextStyle}" Text="{Binding LauncherStatusText}" />
                                    <Button Margin="0,22,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding RefreshCommand}"
                                            Content="TEST NOW" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="18,0,18,0"
                                    Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="AUTOMATION" />
                                    <TextBlock Margin="0,18,0,0" Style="{StaticResource BodyTextStyle}" Text="{Binding RaceDesk.BlockingGuidance}" />
                                    <TextBlock Margin="0,18,0,0" Style="{StaticResource CaptionTextStyle}" Text="RESULT AUTO-COMMIT" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource BodyTextStyle}" Text="High-confidence results commit automatically. Others route through Result Review." />
                                    <TextBlock Margin="0,18,0,0" Style="{StaticResource CaptionTextStyle}" Text="CURRENT PRIMARY ACTION" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource BodyTextStyle}" Text="{Binding RaceDesk.PrimaryAction.Label}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="DISPLAY" />
                                    <TextBlock Margin="0,18,0,0" Style="{StaticResource BodyTextStyle}" Text="Rig Mode, ultrawide behavior, and accessibility controls can bind here as settings persistence is added." />
                                    <CheckBox Margin="0,18,0,0" Foreground="{StaticResource TextMainBrush}" Content="Rig Mode" IsChecked="True" />
                                    <CheckBox Margin="0,10,0,0" Foreground="{StaticResource TextMainBrush}" Content="Ultrawide Mode" IsChecked="True" />
                                    <CheckBox Margin="0,10,0,0" Foreground="{StaticResource TextMainBrush}" Content="High Contrast" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="PROFILES" />
                                    <TextBlock Margin="0,16,0,0" Style="{StaticResource BodyTextStyle}" Text="{Binding ActiveCareerSummaryText}" />
                                    <ListBox Margin="0,16,0,0"
                                             Height="180"
                                             ItemsSource="{Binding Careers}"
                                             SelectedItem="{Binding SelectedCareerSummary}"
                                             Background="#0D151D"
                                             BorderBrush="#243545"
                                             BorderThickness="1"
                                             Foreground="{StaticResource TextMainBrush}" />
                                    <StackPanel Margin="0,16,0,0"
                                                Orientation="Horizontal">
                                        <Button Width="180"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding LoadSelectedCareerCommand}"
                                                Content="LOAD PROFILE" />
                                        <Button Width="180"
                                                Margin="12,0,0,0"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding DeleteSelectedCareerCommand}"
                                                Content="DELETE PROFILE" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Grid.Column="2"
                                    Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="DIAGNOSTICS" />
                                    <WrapPanel Margin="0,16,0,0">
                                        <Border Style="{StaticResource StatusPillStyle}" Margin="0,0,10,10">
                                            <TextBlock Foreground="{StaticResource AccentGreenBrush}" Text="{Binding Diagnostics.LastAutomationStatus}" />
                                        </Border>
                                        <Border Style="{StaticResource StatusPillStyle}" Margin="0,0,10,10">
                                            <TextBlock Foreground="{StaticResource AccentGreenBrush}" Text="{Binding Diagnostics.LastSessionStatus}" />
                                        </Border>
                                    </WrapPanel>
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource CaptionTextStyle}" Text="AUTOMATION TRACE" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource BodyTextStyle}" Text="{Binding Diagnostics.AutomationTracePath}" />
                                    <TextBlock Margin="0,14,0,0" Style="{StaticResource CaptionTextStyle}" Text="TELEMETRY LOG" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource BodyTextStyle}" Text="{Binding Diagnostics.TelemetryLogPath}" />
                                    <TextBlock Margin="0,14,0,0" Style="{StaticResource CaptionTextStyle}" Text="STARTUP ERROR LOG" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource BodyTextStyle}" Text="{Binding Diagnostics.StartupErrorLogPath}" />
                                    <TextBlock Margin="0,14,0,0" Style="{StaticResource CaptionTextStyle}" Text="RUN ID" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource BodyTextStyle}" Text="{Binding Diagnostics.CurrentRunId}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

                                                                           VerticalAlignment="Center"
                                                                           Text="&#xE73E;" />
                                                                <TextBlock Grid.Column="1"
                                                                           Margin="6,0,0,0"
                                                                           FontSize="12"
                                                                           FontWeight="Bold"
                                                                           Text="{Binding StatusText}" />
                                                            </Grid>
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource ReadinessBadgeStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Success">
                                                                            <Setter Property="Background" Value="#0F2411" />
                                                                            <Setter Property="BorderBrush" Value="#38653A" />

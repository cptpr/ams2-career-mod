<Window x:Class="Ams2CareerCompanion.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AMS2 Career Companion"
        Icon="Assets/ams2-career.png"
        Width="1360"
        Height="860"
        MinWidth="1240"
        MinHeight="780"
        Background="#0B1020"
        Foreground="#F3F6FF">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style TargetType="TabControl">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#0B1020" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#EAF1FF" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="26,12" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="#15254A"
                                BorderBrush="#29467A"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2B64FF" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#7DA2FF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#7DA2FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20"
                Margin="0,0,0,16"
                CornerRadius="18"
                Background="#14203D">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="Bold"
                               Text="AMS2 Career Companion" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="#B8C4E6"
                               Text="{Binding StatusMessage}" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="14"
                               Foreground="#89A0D5"
                               Text="{Binding SessionSummary}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right">
                    <TextBlock HorizontalAlignment="Right"
                               FontSize="14"
                               Foreground="#8BD9B6"
                               Text="{Binding ConnectionStateText}" />
                    <TextBlock Margin="0,10,0,0"
                               HorizontalAlignment="Right"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding CurrentTitle}" />
                    <TextBlock Margin="0,4,0,0"
                               HorizontalAlignment="Right"
                               FontSize="14"
                               Foreground="#D3DCFF"
                               Text="{Binding StandingText}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Race">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Border Padding="18"
                                CornerRadius="16"
                                Background="#11192F">
                            <StackPanel>
                                <TextBlock FontSize="22"
                                           FontWeight="Bold"
                                           Text="Race Control" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="13"
                                           Foreground="#9DAACC"
                                           Text="Launch AMS2, run the race manually in-game, and let the companion process the result when the session finishes." />

                                <Button Margin="0,18,0,0"
                                        Padding="14"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Background="#2D63FF"
                                        BorderThickness="0"
                                        Command="{Binding LaunchAms2Command}"
                                        Content="Launch AMS2" />

                                <Button Margin="0,10,0,0"
                                        Padding="14"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Background="#0D96D8"
                                        BorderThickness="0"
                                        Command="{Binding LaunchAms2VrCommand}"
                                        Content="Launch AMS2 In VR" />

                                <Button Margin="0,10,0,0"
                                        Padding="12"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Background="#3E4A6B"
                                        BorderThickness="0"
                                        Command="{Binding RefreshCommand}"
                                        Content="Refresh Status" />

                                <TextBlock Margin="0,18,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="#F3F6FF"
                                           Text="Launcher Status" />
                                <TextBlock Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#D5DDFC"
                                           Text="{Binding LauncherStatusText}" />

                                <TextBlock Margin="0,18,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="#F3F6FF"
                                           Text="Detected Install" />
                                <TextBlock Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#A8B6DA"
                                           Text="{Binding InstallPathText}" />

                                <Border Margin="0,18,0,0"
                                        Padding="14"
                                        CornerRadius="12"
                                        Background="#0F1630">
                                    <StackPanel>
                                        <TextBlock FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#F3F6FF"
                                                   Text="Current Limitation" />
                                        <TextBlock Margin="0,8,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="#D5DDFC"
                                                   Text="The companion can launch AMS2, but it does not yet navigate AMS2 menus or auto-start a race. Start the event manually in-game for now." />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,16,0,0"
                                Padding="18"
                                CornerRadius="16"
                                Background="#11192F"
                                Visibility="{Binding DeveloperToolsEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#F3F6FF"
                                           Text="Developer Tools" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="13"
                                           Foreground="#9DAACC"
                                           Text="These controls generate simulated telemetry for development. They are not normal gameplay flow." />

                                <Button Margin="0,14,0,0"
                                        Padding="12"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Background="#22A06B"
                                        BorderThickness="0"
                                        Command="{Binding SimulateRaceCommand}"
                                        Content="Simulate Clean Race" />

                                <Button Margin="0,10,0,0"
                                        Padding="12"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Background="#C98B1B"
                                        BorderThickness="0"
                                        Command="{Binding SimulateUncertainRaceCommand}"
                                        Content="Simulate Uncertain Race" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="18"
                                    CornerRadius="16"
                                    Background="#11192F">
                                <StackPanel>
                                    <TextBlock FontSize="22"
                                               FontWeight="Bold"
                                               Text="{Binding CurrentCareerName}" />
                                    <TextBlock Margin="0,10,0,0"
                                               FontSize="14"
                                               Foreground="#A6B4D9"
                                               Text="{Binding CurrentStarterCar}" />
                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="{Binding CurrentLeagueName}" />
                                    <TextBlock Margin="0,10,0,0"
                                               FontSize="15"
                                               Text="{Binding ProgressText}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="18"
                                    CornerRadius="16"
                                    Background="#11192F">
                                <StackPanel>
                                    <TextBlock FontSize="22"
                                               FontWeight="Bold"
                                               Text="Featured Rival" />
                                    <TextBlock Margin="0,10,0,0"
                                               FontSize="14"
                                               TextWrapping="Wrap"
                                               Foreground="#D6E1FF"
                                               Text="{Binding FeaturedRivalText}" />
                                    <TextBlock Margin="0,14,0,0"
                                               FontSize="14"
                                               Foreground="#99A6C9"
                                               Text="{Binding RewardSummary}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Padding="18"
                                CornerRadius="16"
                                Background="#11192F">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="360" />
                                </Grid.ColumnDefinitions>

                                <DockPanel Grid.Column="0"
                                           LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Top"
                                               Margin="0,0,0,12"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#F3F6FF"
                                               Text="Recent Results" />
                                    <TextBlock DockPanel.Dock="Top"
                                               Margin="0,0,0,12"
                                               Foreground="#8DA0CF"
                                               Text="{Binding RecentResultsHeaderText}" />
                                    <ListBox ItemsSource="{Binding RecentResults}"
                                             SelectedItem="{Binding SelectedRecentResult}"
                                             Background="#0F1630"
                                             BorderThickness="0"
                                             Foreground="#F3F6FF">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Margin" Value="0,0,0,10" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemBorder"
                                                                    Padding="14"
                                                                    CornerRadius="12"
                                                                    Background="#131D39"
                                                                    BorderBrush="#223761"
                                                                    BorderThickness="1">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#19305C" />
                                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#5C8CFF" />
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#4D75C5" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#F3F6FF"
                                                                   Text="{Binding Headline}" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Foreground="#93A6D4"
                                                                   Text="{Binding Subtitle}" />
                                                        <TextBlock Margin="0,8,0,0"
                                                                   Foreground="#D7E1FF"
                                                                   Text="{Binding DetailLine}" />
                                                    </StackPanel>

                                                    <Border Grid.Column="1"
                                                            Margin="12,0,0,0"
                                                            Padding="10,5"
                                                            VerticalAlignment="Top"
                                                            CornerRadius="999"
                                                            Background="#243D73">
                                                        <TextBlock FontSize="12"
                                                                   FontWeight="Bold"
                                                                   Foreground="#EAF1FF"
                                                                   Text="{Binding ResultTag}" />
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>

                                <Border Grid.Column="2"
                                        Padding="14"
                                        CornerRadius="12"
                                        Background="#0F1630">
                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#F3F6FF"
                                                   Text="Selected Result" />
                                        <TextBlock Margin="0,10,0,0"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#DDE6FF"
                                                   Text="{Binding SelectedRecentResultHeadline}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="#D5DDFC"
                                                   Text="{Binding SelectedRecentResultDetails}" />
                                        <TextBlock Margin="0,18,0,0"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#F3F6FF"
                                                   Text="Manual Review" />
                                        <TextBlock Margin="0,10,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="#D5DDFC"
                                                   Text="{Binding PendingDraftSummary}" />
                                        <Button Margin="0,16,0,0"
                                                Padding="12"
                                                FontWeight="SemiBold"
                                                Background="#8E58FF"
                                                BorderThickness="0"
                                                Command="{Binding ConfirmPendingResultCommand}"
                                                Content="Confirm Pending Result" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Career">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="18"
                            CornerRadius="16"
                            Background="#11192F">
                        <StackPanel>
                            <TextBlock FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#F3F6FF"
                                       Text="Career Setup" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="#9DAACC"
                                       Text="Create the save here once, instead of keeping setup controls on the main race screen." />

                            <TextBlock Margin="0,18,0,6"
                                       FontWeight="SemiBold"
                                       Foreground="#F3F6FF"
                                       Text="Career Name" />
                            <TextBox Padding="10"
                                     MaxLength="32"
                                     FontSize="15"
                                     Text="{Binding CareerNameInput, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,6,0,0"
                                       HorizontalAlignment="Right"
                                       Foreground="#8DA0CF"
                                       Text="{Binding CareerNameCharacterCount}" />

                            <TextBlock Margin="0,16,0,6"
                                       FontWeight="SemiBold"
                                       Foreground="#F3F6FF"
                                       Text="Starter Car" />
                            <ComboBox Padding="8"
                                      FontSize="15"
                                      ItemsSource="{Binding StarterCars}"
                                      SelectedItem="{Binding SelectedStarterCar}"
                                      DisplayMemberPath="DisplayLabel" />

                            <Button Margin="0,18,0,0"
                                    Padding="12"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Background="#2D63FF"
                                    BorderThickness="0"
                                    Command="{Binding CreateCareerCommand}"
                                    Content="Create Career" />

                            <Separator Margin="0,18,0,18" />

                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#F3F6FF"
                                       Text="Career Profiles" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="#9DAACC"
                                       Text="{Binding AvailableCareersText}" />
                            <ListBox Margin="0,12,0,0"
                                     Height="220"
                                     ItemsSource="{Binding Careers}"
                                     SelectedItem="{Binding SelectedCareerSummary}"
                                     DisplayMemberPath="DisplayLabel"
                                     Background="#0F1630"
                                     BorderThickness="0"
                                     Foreground="#F3F6FF" />
                            <Button Margin="0,12,0,0"
                                    Padding="12"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Background="#3E4A6B"
                                    BorderThickness="0"
                                    Command="{Binding LoadSelectedCareerCommand}"
                                    Content="Load Selected Career" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="18"
                            CornerRadius="16"
                            Background="#11192F">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top"
                                       Margin="0,0,0,12"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#F3F6FF"
                                       Text="Unlocked Leagues" />
                            <ListBox ItemsSource="{Binding UnlockedLeagues}"
                                     Background="#0F1630"
                                     BorderThickness="0"
                                     Foreground="#F3F6FF" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Challenges">
                <Border Margin="0,16,0,0"
                        Padding="18"
                        CornerRadius="16"
                        Background="#11192F">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Margin="0,0,0,12"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#F3F6FF"
                                   Text="Challenges" />
                        <ListBox ItemsSource="{Binding Challenges}"
                                 Background="#0F1630"
                                 BorderThickness="0"
                                 Foreground="#F3F6FF" />
                    </DockPanel>
                </Border>
            </TabItem>

            <TabItem Header="Rivals">
                <Border Margin="0,16,0,0"
                        Padding="18"
                        CornerRadius="16"
                        Background="#11192F">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Margin="0,0,0,12"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#F3F6FF"
                                   Text="Rivals" />
                        <ListBox ItemsSource="{Binding Rivals}"
                                 Background="#0F1630"
                                 BorderThickness="0"
                                 Foreground="#F3F6FF" />
                    </DockPanel>
                </Border>
            </TabItem>

            <TabItem Header="Settings">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="18"
                            CornerRadius="16"
                            Background="#11192F">
                        <StackPanel>
                            <TextBlock FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#F3F6FF"
                                       Text="Settings" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="#9DAACC"
                                       Text="Current settings are local UI controls for launcher and development visibility. Persisted settings can be added next." />

                            <CheckBox Margin="0,18,0,0"
                                      IsChecked="{Binding DeveloperToolsEnabled}"
                                      Foreground="#F3F6FF"
                                      Content="Show developer simulation tools" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#8DA0CF"
                                       Text="{Binding DeveloperToolsVisibilityText}" />

                            <Button Margin="0,18,0,0"
                                    Padding="12"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Background="#3E4A6B"
                                    BorderThickness="0"
                                    Command="{Binding RefreshCommand}"
                                    Content="Refresh Launcher Detection" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="18"
                            CornerRadius="16"
                            Background="#11192F">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#F3F6FF"
                                       Text="Detection Details" />
                            <TextBlock Margin="0,12,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="#F3F6FF"
                                       Text="Launcher Status" />
                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#D5DDFC"
                                       Text="{Binding LauncherStatusText}" />

                            <TextBlock Margin="0,16,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="#F3F6FF"
                                       Text="Install Path" />
                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#A8B6DA"
                                       Text="{Binding InstallPathText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2"
                   Margin="4,14,0,0"
                   FontSize="12"
                   Foreground="#7381A7"
                   Text="Real AMS2 launch is available. Race menu automation and deeper settings persistence are still pending." />
    </Grid>
</Window>

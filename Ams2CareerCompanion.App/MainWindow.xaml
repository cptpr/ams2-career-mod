<Window x:Class="Ams2CareerCompanion.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AMS2 Career"
        Icon="Assets/ams2-career.png"
        Width="1600"
        Height="980"
        MinWidth="1480"
        MinHeight="860"
        Background="#05090E"
        Foreground="#F2F4F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="BgRootBrush" Color="#05090E" />
        <SolidColorBrush x:Key="BgPanelBrush" Color="#0B121A" />
        <SolidColorBrush x:Key="BgPanelAltBrush" Color="#0E1620" />
        <SolidColorBrush x:Key="BgCardBrush" Color="#101922" />
        <SolidColorBrush x:Key="BgCardSoftBrush" Color="#121D28" />
        <SolidColorBrush x:Key="BorderBrushMain" Color="#1E2A36" />
        <SolidColorBrush x:Key="TextMainBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="TextSoftBrush" Color="#A6B2BF" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#738191" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="#D62C1A" />
        <SolidColorBrush x:Key="AccentRedSoftBrush" Color="#5A1817" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#67D13B" />
        <SolidColorBrush x:Key="AccentAmberBrush" Color="#FFB545" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#3A91FF" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#7A57F5" />

        <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#152230" Offset="0" />
            <GradientStop Color="#0B121A" Offset="0.55" />
            <GradientStop Color="#182127" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="#091018" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource AccentRedBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                BorderBrush="#F36457"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#16212C" />
            <Setter Property="BorderBrush" Value="#2B3C4D" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="14,11" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <TabPanel Height="0"
                                      IsItemsHost="True"
                                      Visibility="Collapsed" />
                            <ContentPresenter ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="ItemRoot"
                                Margin="14,0,14,10"
                                Padding="18,16"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="14">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#571615" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#8A261B" />
                                <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#101922" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarHeaderGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="#D6DDE7" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SidebarHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D6DDE7" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,16" />
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#172632"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0E1821" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#243545" />
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#6C1714" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#B3281D" />
                                <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#0E1A12" />
            <Setter Property="BorderBrush" Value="#284B2D" />
        </Style>

        <Style x:Key="ReadinessBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#111A21" />
            <Setter Property="BorderBrush" Value="#2A3A4A" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgRootBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="206" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="92" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Grid.Column="0"
                Margin="4,4,0,18"
                Background="#071018"
                BorderBrush="{StaticResource BorderBrushMain}"
                BorderThickness="1"
                CornerRadius="0,24,24,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="18,20,18,18">
                    <Image Source="Assets/ams2-career-brand.png"
                           Width="162"
                           Stretch="Uniform"
                           HorizontalAlignment="Left" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="4,8,4,12">
                    <Button Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowRaceDeskPageCommand}"
                            Tag="{Binding IsRaceDeskPageSelected}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarHeaderGlyphStyle}" Text="&#xEB8B;" />
                            <TextBlock Margin="14,0,0,0" Style="{StaticResource SidebarHeaderTextStyle}" Text="RACE DESK" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,8,0,0"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowCareerPageCommand}"
                            Tag="{Binding IsCareerPageSelected}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarHeaderGlyphStyle}" Text="&#xE8D2;" />
                            <TextBlock Margin="14,0,0,0" Style="{StaticResource SidebarHeaderTextStyle}" Text="CAREER" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,8,0,0"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowGaragePageCommand}"
                            Tag="{Binding IsGaragePageSelected}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarHeaderGlyphStyle}" Text="&#xEC47;" />
                            <TextBlock Margin="14,0,0,0" Style="{StaticResource SidebarHeaderTextStyle}" Text="GARAGE" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,8,0,0"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowTeamHqPageCommand}"
                            Tag="{Binding IsTeamHqPageSelected}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarHeaderGlyphStyle}" Text="&#xE821;" />
                            <TextBlock Margin="14,0,0,0" Style="{StaticResource SidebarHeaderTextStyle}" Text="TEAM HQ" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,8,0,0"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowRivalsPageCommand}"
                            Tag="{Binding IsRivalsPageSelected}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarHeaderGlyphStyle}" Text="&#xE902;" />
                            <TextBlock Margin="14,0,0,0" Style="{StaticResource SidebarHeaderTextStyle}" Text="RIVALS" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,8,0,0"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowHistoryPageCommand}"
                            Tag="{Binding IsHistoryPageSelected}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarHeaderGlyphStyle}" Text="&#xE81C;" />
                            <TextBlock Margin="14,0,0,0" Style="{StaticResource SidebarHeaderTextStyle}" Text="HISTORY" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,8,0,0"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowSettingsPageCommand}"
                            Tag="{Binding IsSettingsPageSelected}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarHeaderGlyphStyle}" Text="&#xE713;" />
                            <TextBlock Margin="14,0,0,0" Style="{StaticResource SidebarHeaderTextStyle}" Text="SETTINGS" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Margin="18,0,0,18"
                           Style="{StaticResource CaptionTextStyle}"
                           Text="v1.2.0" />
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="2"
                Margin="0,14,18,14"
                Background="#091018"
                BorderBrush="{StaticResource BorderBrushMain}"
                BorderThickness="1"
                CornerRadius="20">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="136" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="190" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="48"
                             Height="48"
                             Fill="#1B2630"
                             Stroke="#314150"
                             StrokeThickness="1" />
                    <StackPanel Margin="14,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMainBrush}"
                                   Text="{Binding Profile.Name}" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}"
                                   Text="Active Profile" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="LEVEL" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Text="{Binding Profile.Level}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="DRIVER RATING" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Text="{Binding Profile.DriverRating, StringFormat={}{0:0}}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="CREDITS" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Text="{Binding Profile.Credits, StringFormat={}{0:N0}}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="REPUTATION" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Text="{Binding Profile.Reputation}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="5"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="AMS2 CONNECTION" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   Text="{Binding ConnectionStateText}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="TELEMETRY HEALTH" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   Text="{Binding TelemetryHealthText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <ScrollViewer x:Name="PageHostScrollViewer"
                          Grid.Row="1"
                          Grid.Column="2"
                          Margin="0,0,18,18"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          PreviewMouseWheel="PageHostScrollViewer_OnPreviewMouseWheel"
                          Padding="0,0,6,0">
                <TabControl SelectedIndex="{Binding SelectedPageIndex}"
                            Background="Transparent">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource SidebarHeaderGlyphStyle}" Text="&#xEB8B;" />
                        <TextBlock Margin="14,0,0,0" Style="{StaticResource SidebarHeaderTextStyle}" Text="RACE DESK" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.15*" />
                            <ColumnDefinition Width="0.95*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                MinHeight="340"
                                Style="{StaticResource CardBorderStyle}"
                                Background="{StaticResource HeroGradientBrush}"
                                Padding="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="0.78*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="NEXT EVENT" />
                                    <TextBlock Margin="0,10,0,0"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextMainBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding NextEventDisplayTitle}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="{Binding NextEventDisplaySubtitle}" />

                                    <Grid Margin="0,24,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Margin="0,0,10,0"
                                                Style="{StaticResource CardBorderStyle}"
                                                Background="#101821">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="TRACK" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding RaceDesk.EventPlan.Plan.TrackDisplayName}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           Text="{Binding RaceDesk.EventPlan.Plan.Country}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1"
                                                Margin="10,0,0,0"
                                                Style="{StaticResource CardBorderStyle}"
                                                Background="#101821">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="CAR / CLASS" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding CurrentStarterCar}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           Text="{Binding RaceDesk.EventPlan.Plan.PlayerCarClassName}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Margin="0,18,0,0"
                                            Style="{StaticResource CardBorderStyle}"
                                            Background="#101821">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="ROUND" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding NextEventRoundDisplay}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="SESSION" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding NextEventSessionDisplay}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="REWARDS PREVIEW" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentAmberBrush}"
                                                           Text="{Binding NextEventRewardCreditsText}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Style="{StaticResource CaptionTextStyle}"
                                                           Foreground="{StaticResource AccentGreenBrush}"
                                                           Text="{Binding NextEventRewardXpText}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Margin="22,0,0,0"
                                        CornerRadius="20"
                                        BorderBrush="#2A3642"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#202A33" Offset="0" />
                                                <GradientStop Color="#182028" Offset="0.4" />
                                                <GradientStop Color="#0E141A" Offset="1" />
                                            </LinearGradientBrush>
                                        </Grid.Background>
                                        <Rectangle Margin="18"
                                                   RadiusX="16"
                                                   RadiusY="16"
                                                   Fill="#1E2933"
                                                   Opacity="0.55" />
                                        <StackPanel VerticalAlignment="Bottom"
                                                    Margin="24">
                                            <TextBlock FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RaceDesk.EventPlan.Plan.TrackDisplayName}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Text="{Binding NextEventHeroMetaText}" />
                                            <TextBlock Margin="0,12,0,0"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       Text="{Binding NextEventOverlapGuidanceText}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Margin="14,0,0,0"
                                Style="{StaticResource CardBorderStyle}">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="EVENT READINESS" />
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="{Binding RaceDesk.Automation.Headline}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="{Binding RaceDesk.BlockingGuidance}" />
                                </StackPanel>

                                <StackPanel Margin="0,18,0,0">
                                    <ItemsControl ItemsSource="{Binding RaceDesk.ReadinessChecklist}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="14"
                                                        Background="#0D151D"
                                                        BorderBrush="#243545"
                                                        BorderThickness="1"
                                                        CornerRadius="14">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="28"
                                                                Height="28"
                                                                CornerRadius="14"
                                                                Background="#13202C"

                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Title}" />
                                                            <TextBlock Margin="0,6,0,0"
                                                                       Style="{StaticResource CaptionTextStyle}"
                                                                       Text="{Binding Detail}" />
                                                        </StackPanel>
                                                        <Border Grid.Column="2">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

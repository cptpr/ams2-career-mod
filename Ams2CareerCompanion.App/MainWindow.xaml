<Window x:Class="Ams2CareerCompanion.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AMS2 Career"
        Icon="Assets/ams2-career.png"
        Width="1600"
        Height="980"
        MinWidth="1480"
        MinHeight="860"
        Background="#05090E"
        Foreground="#F2F4F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="BgRootBrush" Color="#05090E" />
        <SolidColorBrush x:Key="BgPanelBrush" Color="#0B121A" />
        <SolidColorBrush x:Key="BgPanelAltBrush" Color="#0E1620" />
        <SolidColorBrush x:Key="BgCardBrush" Color="#101922" />
        <SolidColorBrush x:Key="BgCardSoftBrush" Color="#121D28" />
        <SolidColorBrush x:Key="BorderBrushMain" Color="#1E2A36" />
        <SolidColorBrush x:Key="TextMainBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="TextSoftBrush" Color="#A6B2BF" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#738191" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="#D62C1A" />
        <SolidColorBrush x:Key="AccentRedSoftBrush" Color="#5A1817" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#67D13B" />
        <SolidColorBrush x:Key="AccentAmberBrush" Color="#FFB545" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#3A91FF" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#7A57F5" />

        <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#152230" Offset="0" />
            <GradientStop Color="#0B121A" Offset="0.55" />
            <GradientStop Color="#182127" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="#091018" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource AccentRedBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                BorderBrush="#F36457"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#16212C" />
            <Setter Property="BorderBrush" Value="#2B3C4D" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="14,11" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="210" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,22,0"
                                    Background="#071018"
                                    BorderBrush="{StaticResource BorderBrushMain}"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="20,22,20,16">
                                        <Image Source="Assets/ams2-career.png"
                                               Width="112"
                                               Height="64"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Left" />
                                    </StackPanel>

                                    <TabPanel Grid.Row="1"
                                              Margin="0,14,0,12"
                                              IsItemsHost="True" />

                                    <StackPanel Grid.Row="2"
                                                Margin="20,0,20,20">
                                        <Border Width="38"
                                                Height="38"
                                                Background="#0D1620"
                                                BorderBrush="#223140"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSoftBrush}"
                                                       Text="&#xE76B;" />
                                        </Border>
                                        <TextBlock Margin="0,10,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="v1.2.0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="Transparent">
                                <ContentPresenter ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="ItemRoot"
                                Margin="14,0,14,10"
                                Padding="18,16"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="14">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#571615" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#8A261B" />
                                <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#101922" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarHeaderGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="#D6DDE7" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SidebarHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D6DDE7" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatusPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#0E1A12" />
            <Setter Property="BorderBrush" Value="#284B2D" />
        </Style>

        <Style x:Key="ReadinessBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#111A21" />
            <Setter Property="BorderBrush" Value="#2A3A4A" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgRootBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="90" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="18,18,18,14"
                Background="#091018"
                BorderBrush="{StaticResource BorderBrushMain}"
                BorderThickness="1"
                CornerRadius="20">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="0.6*" />
                    <ColumnDefinition Width="0.8*" />
                    <ColumnDefinition Width="0.9*" />
                    <ColumnDefinition Width="0.9*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="48"
                             Height="48"
                             Fill="#1B2630"
                             Stroke="#314150"
                             StrokeThickness="1" />
                    <StackPanel Margin="14,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMainBrush}"
                                   Text="{Binding Profile.Name}" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}"
                                   Text="Active Profile" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="LEVEL" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Text="{Binding Profile.Level}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="DRIVER RATING" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Text="{Binding Profile.DriverRating, StringFormat={}{0:0}}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="CREDITS" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Text="{Binding Profile.Credits, StringFormat={}{0:N0}}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="REPUTATION" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Text="{Binding Profile.Reputation}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="5"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="AMS2 CONNECTION" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   Text="{Binding ConnectionStateText}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="TELEMETRY HEALTH" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   Text="{Binding TelemetryHealthText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="18,0,18,18"
                    TabStripPlacement="Left">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource SidebarHeaderGlyphStyle}" Text="&#xEB8B;" />
                        <TextBlock Margin="14,0,0,0" Style="{StaticResource SidebarHeaderTextStyle}" Text="RACE DESK" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.05*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource CardBorderStyle}"
                                Background="{StaticResource HeroGradientBrush}"
                                Padding="26">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="NEXT EVENT" />
                                    <TextBlock Margin="0,12,0,0"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextMainBrush}"
                                               Text="{Binding RaceDesk.EventPlan.Headline}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="{Binding CurrentLeagueName}" />

                                    <Grid Margin="0,28,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Margin="0,0,10,0"
                                                Style="{StaticResource CardBorderStyle}"
                                                Background="#101821">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="TRACK" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="20"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding RaceDesk.EventPlan.Plan.TrackDisplayName}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           Text="{Binding RaceDesk.EventPlan.Plan.Country}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1"
                                                Margin="10,0,0,0"
                                                Style="{StaticResource CardBorderStyle}"
                                                Background="#101821">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="CAR / CLASS" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="20"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding CurrentStarterCar}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           Text="{Binding RaceDesk.EventPlan.Plan.PlayerCarClassName}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Margin="0,18,0,0"
                                            Style="{StaticResource CardBorderStyle}"
                                            Background="#101821">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="ROUND" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding RaceDesk.EventPlan.Plan.EventNumber}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="SESSION" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding RaceDesk.EventPlan.Plan.EventTemplateName}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="REWARDS PREVIEW" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentAmberBrush}"
                                                           Text="{Binding RewardSummary}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Margin="28,0,0,0"
                                        CornerRadius="20"
                                        BorderBrush="#2A3642"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#202A33" Offset="0" />
                                                <GradientStop Color="#182028" Offset="0.4" />
                                                <GradientStop Color="#0E141A" Offset="1" />
                                            </LinearGradientBrush>
                                        </Grid.Background>
                                        <StackPanel VerticalAlignment="Bottom"
                                                    Margin="24">
                                            <TextBlock FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RaceDesk.EventPlan.Plan.TrackDisplayName}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       Text="{Binding RaceDesk.EventPlan.Details}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Margin="18,0,0,0"
                                Style="{StaticResource CardBorderStyle}">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="EVENT READINESS" />
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="{Binding RaceDesk.BlockingGuidance}" />
                                </StackPanel>

                                <StackPanel Margin="0,18,0,0">
                                    <ItemsControl ItemsSource="{Binding RaceDesk.ReadinessChecklist}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="14"
                                                        Background="#0D151D"
                                                        BorderBrush="#1F2A35"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Title}" />
                                                            <TextBlock Margin="0,6,0,0"
                                                                       Style="{StaticResource CaptionTextStyle}"
                                                                       Text="{Binding Detail}" />
                                                        </StackPanel>
                                                        <Border Grid.Column="1">
                                                            <TextBlock FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Text="{Binding StatusText}" />
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource ReadinessBadgeStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Success">
                                                                            <Setter Property="Background" Value="#0F2411" />
                                                                            <Setter Property="BorderBrush" Value="#38653A" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                            <Setter Property="Background" Value="#2B1F11" />
                                                                            <Setter Property="BorderBrush" Value="#7A5A1E" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                                            <Setter Property="Background" Value="#2B1717" />
                                                                            <Setter Property="BorderBrush" Value="#6D2A2A" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Margin="0,18,0,0"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding RaceDesk.PrimaryAction.Command}"
                                            Content="{Binding RaceDesk.PrimaryAction.Label}"
                                            IsEnabled="{Binding RaceDesk.PrimaryAction.IsEnabled}"
                                            Visibility="{Binding RaceDesk.PrimaryAction.IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <Button Margin="0,10,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding RaceDesk.SecondaryAction.Command}"
                                            Content="{Binding RaceDesk.SecondaryAction.Label}"
                                            IsEnabled="{Binding RaceDesk.SecondaryAction.IsEnabled}"
                                            Visibility="{Binding RaceDesk.SecondaryAction.IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="2"
                              Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,14,0"
                                    Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="PRE-RACE CHECKLIST" />
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="AMS2 still requires confirmation in-game. Use this checklist as the guided handoff between the desk and the sim." />
                                    <ItemsControl Margin="0,18,0,0"
                                                  ItemsSource="{Binding RaceDesk.ReadinessChecklist}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="26"
                                                            Height="26"
                                                            CornerRadius="8"
                                                            Background="#161F27"
                                                            BorderBrush="#283542"
                                                            BorderThickness="1">
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="12"
                                                                   FontWeight="Bold"
                                                                   Text="•" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1"
                                                                Margin="12,0,0,0">
                                                        <TextBlock FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Title}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Style="{StaticResource CaptionTextStyle}"
                                                                   Text="{Binding Detail}" />
                                                    </StackPanel>
                                                    <Border Grid.Column="2"
                                                            Style="{StaticResource ReadinessBadgeStyle}">
                                                        <TextBlock FontSize="11"
                                                                   FontWeight="Bold"
                                                                   Text="{Binding StatusText}" />
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="0,0,14,0"
                                    Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="RIVAL SPOTLIGHT" />
                                    <Border Margin="0,16,0,0"
                                            Height="120"
                                            Background="#151D25"
                                            BorderBrush="#253443"
                                            BorderThickness="1"
                                            CornerRadius="14" />
                                    <TextBlock Margin="0,16,0,0"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="{Binding FeaturedRivalText}" />
